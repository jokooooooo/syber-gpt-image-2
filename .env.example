# FastAPI backend defaults.
SUB2API_BASE_URL="http://127.0.0.1:9878/v1"
SUB2API_AUTH_BASE_URL="http://127.0.0.1:9878"
SUB2API_USAGE_PATH="/v1/usage"
IMAGE_MODEL="gpt-image-2"
PROMPT_OPTIMIZER_MODEL="gpt-5.5"
IMAGE_SIZE="2K"
IMAGE_QUALITY="auto"
IMAGE_PRICE_1K_USD="0.134"
IMAGE_PRICE_2K_USD="0.201"
IMAGE_PRICE_4K_USD="0.268"
DATABASE_PATH="./backend/data/app.sqlite3"
STORAGE_DIR="./backend/storage"
PROVIDER_TIMEOUT_SECONDS="300"
SESSION_COOKIE_NAME="cybergen_session"
GUEST_COOKIE_NAME="cybergen_guest"
SESSION_TTL_SECONDS="2592000"
GUEST_TTL_SECONDS="2592000"
COOKIE_SECURE="false"
INSPIRATION_SOURCE_URLS="https://raw.githubusercontent.com/EvoLinkAI/awesome-gpt-image-2-prompts/main/README.md,https://raw.githubusercontent.com/YouMind-OpenLab/awesome-gpt-image-2/main/README.md"
INSPIRATION_SYNC_INTERVAL_SECONDS="21600"
INSPIRATION_SYNC_ON_STARTUP="true"

# Optional frontend override. Leave empty when using Vite proxy.
VITE_API_BASE_URL=""
